# Application Configurations
PROJECT_NAME="FitNova AI Backend"
VERSION=1.0.0
API_V1_STR=/api/v1
LOG_LEVEL=INFO

# CORS Configuration (comma-separated list or JSON list)
BACKEND_CORS_ORIGINS=["*"]

# Database Configurations (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=fitnova
POSTGRES_PORT=5432

# Optional Database URL override (e.g., if using a cloud DB or special driver)
# DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/fitnova

# Whisper Configurations (tiny, base, small, medium, large)
# Use 'base' for fast local English demos, 'medium' is the minimum for multilingual accuracy.
WHISPER_MODEL=base
WHISPER_MOCK=False

# Hugging Face Authentication Token (Required for pyannote speaker diarization)
HF_TOKEN=your_hugging_face_token

# Diarization Configurations
DIARIZATION_MOCK=False
PYANNOTE_CLUSTERING_THRESHOLD=0.55
DIARIZATION_NUM_SPEAKERS=2

# LLM Provider Configuration (openai, groq, mock)
LLM_PROVIDER=groq

# OpenAI Configuration (Used if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Groq Configuration (Used if LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
